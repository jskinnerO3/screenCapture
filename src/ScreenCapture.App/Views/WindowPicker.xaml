<Window x:Class="ScreenCapture.App.Views.WindowPicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Window to Capture"
        Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select a window to capture:"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,16"/>

        <ListBox Grid.Row="1" x:Name="WindowList"
                 SelectionMode="Single"
                 BorderThickness="1"
                 BorderBrush="#E0E0E0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="8,4">
                        <TextBlock Text="{Binding Title}" FontSize="14"
                                   MaxWidth="350" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding Bounds, StringFormat=' ({0})'}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Style="{StaticResource PrimaryButton}"
                    Background="#757575" Click="CancelButton_Click" Margin="0,0,8,0"/>
            <Button Content="Select" Style="{StaticResource PrimaryButton}"
                    Click="SelectButton_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
