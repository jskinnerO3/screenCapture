<Window x:Class="ScreenCapture.App.Views.RecordingControls"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recording"
        Height="60" Width="250"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#E0212121" CornerRadius="8" Padding="12,8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Recording indicator -->
            <Ellipse x:Name="RecordingIndicator" Grid.Column="0"
                     Width="12" Height="12" Fill="Red" Margin="0,0,8,0">
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1.0" To="0.3" Duration="0:0:0.5"
                                                 AutoReverse="True"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>

            <!-- Duration -->
            <TextBlock x:Name="DurationText" Grid.Column="1"
                       Text="00:00:00" Foreground="White"
                       FontSize="16" FontFamily="Consolas"
                       VerticalAlignment="Center"/>

            <!-- Pause/Resume -->
            <Button x:Name="PauseButton" Grid.Column="2"
                    Width="32" Height="32" Margin="8,0"
                    Background="Transparent" BorderThickness="0"
                    Click="PauseButton_Click" Cursor="Hand">
                <TextBlock x:Name="PauseIcon" Text="⏸" Foreground="White" FontSize="16"/>
            </Button>

            <!-- Stop -->
            <Button x:Name="StopButton" Grid.Column="3"
                    Width="32" Height="32"
                    Background="Transparent" BorderThickness="0"
                    Click="StopButton_Click" Cursor="Hand">
                <Rectangle Width="14" Height="14" Fill="White"/>
            </Button>

            <!-- Close -->
            <Button Grid.Column="4" Width="24" Height="24" Margin="8,0,0,0"
                    Background="Transparent" BorderThickness="0"
                    Click="CloseButton_Click" Cursor="Hand">
                <TextBlock Text="✕" Foreground="#888888" FontSize="12"/>
            </Button>
        </Grid>
    </Border>
</Window>
