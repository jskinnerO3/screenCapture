<Window x:Class="ScreenCapture.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ScreenCapture.App.ViewModels"
        Title="Settings"
        Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        ResizeMode="NoResize">

    <Window.DataContext>
        <vm:SettingsViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel>
                <!-- General Settings -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="General" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Save Location:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding SavePath}" Style="{StaticResource ModernTextBox}" Margin="8,0"/>
                            <Button Grid.Column="2" Content="Browse" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding BrowseSavePathCommand}" Padding="12,6"/>
                        </Grid>

                        <CheckBox Content="Copy to clipboard after capture" IsChecked="{Binding CopyToClipboardAfterCapture}" Margin="0,8"/>
                        <CheckBox Content="Show preview after capture" IsChecked="{Binding ShowPreviewAfterCapture}" Margin="0,8"/>
                        <CheckBox Content="Play sound on capture" IsChecked="{Binding PlaySound}" Margin="0,8"/>
                        <CheckBox Content="Start minimized" IsChecked="{Binding StartMinimized}" Margin="0,8"/>
                        <CheckBox Content="Minimize to system tray" IsChecked="{Binding MinimizeToTray}" Margin="0,8"/>
                        <CheckBox Content="Run at Windows startup" IsChecked="{Binding RunAtStartup}" Margin="0,8"/>
                    </StackPanel>
                </Border>

                <!-- Image Settings -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Image Settings" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Default Format:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding ImageFormats}"
                                      SelectedItem="{Binding ImageFormat}" Width="120" HorizontalAlignment="Left"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="JPEG Quality:" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Slider Value="{Binding JpegQuality}" Minimum="1" Maximum="100" Width="200"/>
                                <TextBlock Text="{Binding JpegQuality, StringFormat={}{0}%}" Margin="8,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Recording Settings -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Recording Settings" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Frame Rate:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding FrameRates}"
                                      SelectedItem="{Binding RecordingFrameRate}" Width="80" HorizontalAlignment="Left"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Video Quality:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding VideoQualities}"
                                      SelectedItem="{Binding VideoQuality}" Width="100" HorizontalAlignment="Left"/>
                        </Grid>

                        <CheckBox Content="Capture system audio" IsChecked="{Binding CaptureSystemAudio}" Margin="0,8"/>
                        <CheckBox Content="Capture microphone" IsChecked="{Binding CaptureMicrophone}" Margin="0,8"/>
                    </StackPanel>
                </Border>

                <!-- Hotkeys Info -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Keyboard Shortcuts" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Full Screen Capture" Grid.Row="0"/>
                            <TextBlock Text="Print Screen" Grid.Row="0" Grid.Column="1" Foreground="{StaticResource TextSecondaryBrush}"/>

                            <TextBlock Text="Active Window Capture" Grid.Row="1" Margin="0,8,0,0"/>
                            <TextBlock Text="Alt + Print Screen" Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>

                            <TextBlock Text="Region Selection" Grid.Row="2" Margin="0,8,0,0"/>
                            <TextBlock Text="Ctrl + Shift + S" Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>

                            <TextBlock Text="Start/Stop Recording" Grid.Row="3" Margin="0,8,0,0"/>
                            <TextBlock Text="Ctrl + Shift + R" Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="16">
            <Grid>
                <Button Content="Reset to Defaults" Style="{StaticResource PrimaryButton}"
                        Background="#757575" HorizontalAlignment="Left"
                        Command="{Binding ResetToDefaultsCommand}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Style="{StaticResource PrimaryButton}"
                            Background="#757575" Click="CancelButton_Click" Margin="0,0,8,0"/>
                    <Button Content="Save" Style="{StaticResource PrimaryButton}"
                            Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
